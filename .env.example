# ============================================================
# TyAgent / GeoAgent V1.0 - 环境变量样例
# 使用方式：复制为 .env 后填入真实值；.env 已被 .gitignore 忽略
# ============================================================

# --- 应用 ---
APP_NAME=TyAgent
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- 数据库（PostgreSQL，会话与消息存储；必须使用 asyncpg 驱动） ---
# 占位示例，请按真实环境修改
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tyagent

# --- Milvus 向量库（3.5 阶段启用） ---
# 本地 Docker standalone 示例：
#   MILVUS_URI=http://localhost:19530
# Zilliz Cloud 示例：
#   MILVUS_URI=https://xxxx.api.gcp-us-west1.zillizcloud.com
#   MILVUS_TOKEN=<cluster_token>
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=knowledge_chunks

# --- Embedding 模型（3.5 阶段启用，独立于 chat 模型） ---
# 经由 LiteLLM 统一调用。常见配置：
#   SiliconFlow（推荐，Qwen3-Embedding-8B 直接可用）：
#     EMBEDDING_MODEL=openai/Qwen/Qwen3-Embedding-8B
#     EMBEDDING_API_BASE=https://api.siliconflow.cn/v1
#   阿里 DashScope（OpenAI 兼容模式）：
#     EMBEDDING_MODEL=openai/text-embedding-v3
#     EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# 注意：dimensions 必须与 Milvus Collection 的 vector 维度一致（默认 4096）
EMBEDDING_MODEL=openai/Qwen/Qwen3-Embedding-8B
EMBEDDING_API_KEY=sk-xxxxxxxxxxxxxxxx
EMBEDDING_API_BASE=https://api.siliconflow.cn/v1
EMBEDDING_DIMENSION=4096

# --- RAG 权限基线（V1.0 硬编码，3.6 接入用户体系后再替换） ---
RAG_DEFAULT_ROLE=ALL

# --- Neo4j 知识图谱（3.6 阶段启用） ---
# 默认账号与本仓库 docker-compose/docker-compose.yml 中 NEO4J_AUTH 对齐：
#   neo4j / tyagent_neo4j
# 若手动改密，必须同步修改这里
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=tyagent_neo4j
# 数据库名（社区版固定 "neo4j"，企业版可自建多库）
NEO4J_DATABASE=neo4j

# --- 知识图谱 NER（3.6 阶段启用） ---
# 留空则复用 LITELLM_MODEL / LITELLM_API_KEY / LITELLM_API_BASE
# 实践建议：NER 使用**非 reasoning** 的轻量快速模型，避免推理模型"过度思考"
# 导致大量返回 entities=[]。例如：
#   - DeepSeek:  KG_NER_MODEL=deepseek-v4-flash  （而非 deepseek-v4-pro）
#   - 智谱:      KG_NER_MODEL=zhipu/glm-4-flash
KG_NER_MODEL=deepseek-v4-flash



# --- LLM 网关（3.2 阶段已启用）---
# 模型命名规范：必须带厂商前缀（如 deepseek/deepseek-chat）；
# 若未带前缀，客户端会根据 API_BASE 自动推断（仅对已知厂商域名）。
# 切换厂商示例：
#   DeepSeek: LITELLM_MODEL=deepseek/deepseek-chat        API_BASE=https://api.deepseek.com
#   Qwen:     LITELLM_MODEL=dashscope/qwen-max            API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
#   GLM:      LITELLM_MODEL=zhipu/glm-4                   API_BASE=https://open.bigmodel.cn/api/paas/v4
LITELLM_MODEL=deepseek/deepseek-chat
LITELLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LITELLM_API_BASE=https://api.deepseek.com
# 可选：请求超时（秒）与重试次数
# LITELLM_TIMEOUT=60
# LITELLM_NUM_RETRIES=2

# --- Agent 控制（3.3 阶段启用） ---
# AGENT_MAX_ITERATIONS=5
