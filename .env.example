# ============================================================
# TyAgent / GeoAgent V1.0 - 环境变量样例
# 使用方式：复制为 .env 后填入真实值；.env 已被 .gitignore 忽略
# ============================================================

# --- 应用 ---
APP_NAME=TyAgent
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- 数据库（PostgreSQL + pgvector，必须使用 asyncpg 驱动） ---
# 占位示例，请按真实环境修改
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tyagent

# --- LLM 网关（3.2 阶段已启用）---
# 模型命名规范：必须带厂商前缀（如 deepseek/deepseek-chat）；
# 若未带前缀，客户端会根据 API_BASE 自动推断（仅对已知厂商域名）。
# 切换厂商示例：
#   DeepSeek: LITELLM_MODEL=deepseek/deepseek-chat        API_BASE=https://api.deepseek.com
#   Qwen:     LITELLM_MODEL=dashscope/qwen-max            API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
#   GLM:      LITELLM_MODEL=zhipu/glm-4                   API_BASE=https://open.bigmodel.cn/api/paas/v4
LITELLM_MODEL=deepseek/deepseek-chat
LITELLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LITELLM_API_BASE=https://api.deepseek.com
# 可选：请求超时（秒）与重试次数
# LITELLM_TIMEOUT=60
# LITELLM_NUM_RETRIES=2

# --- Agent 控制（3.3 阶段启用） ---
# AGENT_MAX_ITERATIONS=5
